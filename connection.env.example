# =============================================================================
# Copy to: connection.env   (see lib/loadEnv.js / next.config.mjs)
# Optional overrides: connection.env.local (gitignored)
# =============================================================================

# Supabase PostgreSQL — app reads this via lib/loadEnv (Next + Node).
#
# Schema (database/init.sql) is NOT applied by `npm run dev` (Next only).
# Create tables with:  npm run db:init   OR start Express:  npm run server
#
# For DDL/init, prefer Direct connection (port 5432). Transaction pooler (6543)
# can reject some statements — use Supabase Dashboard → Database → URI → Direct.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# Express JWT (min 16 characters). Used for httpOnly auth_token cookie.
JWT_SECRET=change-me-to-a-long-random-string

# Supabase JS (browser) — Project Settings → API: Project URL + anon (public) key
# Used by the LLM survey page to insert into public.submissions via PostgREST.
# Use the project URL only (https://xxxx.supabase.co) — NOT …/rest/v1/
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Express server (use a free port if Next.js uses 3000, e.g. 4000)
PORT=4000

# Skip automatic database/init.sql on Express startup (schema managed elsewhere)
# SKIP_DB_INIT=1

# Fail DB connect faster when URL is wrong (milliseconds)
# PG_CONNECT_TIMEOUT_MS=8000

# Node pg TLS: default is rejectUnauthorized=false (localhost / Supabase behind proxies).
# In production after validating certs, enable strict verify:
# PG_REJECT_UNAUTHORIZED=true

# =============================================================================
# .env.example — copy to .env.local (Next.js) or connection.env (Express)
# All values are REQUIRED unless marked optional.
# =============================================================================

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (claude-sonnet-4-5-20250929)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── Supabase PostgreSQL (Direct connection for migrations) ───────────────────
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Direct connection" (port 5432) for schema migrations.
# Use the "Transaction pooler" (port 6543) for app queries.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# ─── Supabase JS (browser client) ─────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_ prefix makes these available in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Also expose without prefix so the Express server can read them directly:
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Auth (Express / custom JWT) ──────────────────────────────────────────────
# Min 32 random characters. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ─── Server port (local Express only — Vercel ignores this) ───────────────────
PORT=3000

# ─── Database tweaks (optional) ───────────────────────────────────────────────
# SKIP_DB_INIT=1
# PG_CONNECT_TIMEOUT_MS=8000
# PG_REJECT_UNAUTHORIZED=true
